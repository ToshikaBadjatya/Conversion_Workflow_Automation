      "parameters": {
        "jsCode": "\nconst items = $input.all();\n\nconst filtered = items.filter(item => {\n\n  const output = item.json.output || \"\";\n\n  // Extract percentage number\n  const match = output.match(/(\\d+)%/);\n\n  if (!match) {\n    return false;\n  }\n\n  const percentage = parseInt(match[1], 10);\n\n  return percentage > 60;\n});\n\nreturn filtered;"
      },
