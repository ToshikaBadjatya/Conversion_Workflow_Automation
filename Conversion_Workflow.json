    {
      "parameters": {
        "promptType": "define",
        "text": "=You have to work as a conversion evaluator of an app suno mini where user can create songs, mini songs and craft personality and share share the actions perform and predict the chances of conversion for the users use\n\nInput:\n{{ JSON.stringify($json, null, 2) }}\nOutput Format:- Return outpur conversion probablity value in percentage 100%. Just send the percentage value in output with username \n {{ $json.name }} = percent value\n\n",
        "hasOutputParser": true,
