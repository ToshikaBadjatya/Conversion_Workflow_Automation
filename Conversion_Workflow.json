    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst combinedItems = [];\n\nObject.entries(items[0].json).forEach(([userId, actions]) => {\n\n  let actionsMap = {};\n\n  Object.values(actions).forEach((action) => {\n\n    if (actionsMap[action.action_id]) {\n\n      actionsMap[action.action_id].frequency += 1;\n      actionsMap[action.action_id].timestamp.push(action.timestamp);\n\n    } else {\n\n      actionsMap[action.action_id] = {\n        actionsId: action.action_id,\n        frequency: 1,\n        timestamp: [action.timestamp],\n      };\n\n    }\n\n  });\n\n  combinedItems.push({\n    userId: userId,\n    name: actions[0].user_name,\n    actions: Object.values(actionsMap)\n  });\n\n});\n\nreturn combinedItems;\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
